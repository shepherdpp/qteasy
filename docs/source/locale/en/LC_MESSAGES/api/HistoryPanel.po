#~ msgstr ""
#~ "Parameters used to generate trade_time_index,"
#~ " including: drop_nan: bool Whether to "
#~ "keep all NaN rows resample_method: str"
#~ " Methods for adjusting the frequency "
#~ "if the data needs to be upscaled"
#~ " or downscaled Adjusting the data "
#~ "frequency is categorized into data "
#~ "downscaling and upscaling, and the "
#~ "available methods are different in the"
#~ " two different cases: data downscaling "
#~ "is to merge multiple data into "
#~ "one, so as to reduce the number"
#~ " of data, but retain as much "
#~ "information as possible, for example, "
#~ "merge the following data (each tuple "
#~ "is merged into one value, ? (each"
#~ " tuple is merged into one value, "
#~ "? denotes the merged value) [(1, "
#~ "2, 3), (4, 5), (6, 7)] After "
#~ "merging it becomes: [(?) , (?) ,"
#~ " (?)]     Data merge methods: - "
#~ "'last'/'close': Use the last value of"
#~ " the merge interval. e.g. [(1, 2, "
#~ "3), (4, 5), (6, 7)] after merging"
#~ " becomes: [(3), (5), (7)] - "
#~ "'first'/'open': use the first value of"
#~ " the merge interval. e.g. [(1, 2, "
#~ "3), (4, 5), (6, 7)] merge to: "
#~ "[(1), (4), (6)] - 'max'/'high': Use "
#~ "the maximum of the merge interval "
#~ "as the merge value: [(1, 2, 3),"
#~ " (4, 5), (6, 7)] merge to: "
#~ "[(3), (5), (7)] - 'min'/'low': Use "
#~ "the minimum of the merge interval "
#~ "as the merge value: [(3), (5), "
#~ "(7)] - 'first'/'open': Use the first "
#~ "value of the merge interval. "
#~ "'min'/'low': use the minimum of the "
#~ "merged interval as the merge value: "
#~ "[(1, 2, 3), (4, 5), (6, 7)] "
#~ "after merging becomes: [(1), (4), (6)]"
#~ " - 'avg'/'mean': use the average of"
#~ " the merged interval as the merge "
#~ "value: [(1, 2, 3), (4, 5), (6, "
#~ "7)] after merging becomes: [(2), (4.5),"
#~ " (6.5)] - 'sum'/'total': use the "
#~ "total of the merged interval as "
#~ "the merge value: [(1, 2, 3), (4,"
#~ " 5), (6.5)] - ' sum'/'total': Use "
#~ "the average of the merge intervals "
#~ "as the merge value: [(1, 2, 3),"
#~ " (4, 5), (6, 7)] The merge "
#~ "becomes: [(2), (4.5), (6.5)] The data"
#~ " upscaling is inserting new data into"
#~ " the existing data, and the new "
#~ "data inserted is the missing data, "
#~ "which needs to be filled.     For "
#~ "example, fill the following data (? "
#~ "denotes the inserted data) [1, 2, "
#~ "3] After filling it becomes: [? ,"
#~ " 1, ? , 2, ? , 3, ?]"
#~ "     Missing data is filled as "
#~ "follows: - 'ffill': Fill with the "
#~ "most recent available data before the"
#~ " missing data, if there is no "
#~ "available data, fill with NaN. e.g. "
#~ "[1, 2, 3] Filled with: [NaN, 1,"
#~ " 1, 2, 2, 3, 3] - 'bfill': "
#~ "Fill with the most recent available "
#~ "data after the missing data, if "
#~ "there is no available data, fill "
#~ "with NaN. e.g. [1, 2, 3] fills "
#~ "with: [1, 1, 2, 2, 3, 3, "
#~ "NaN] - 'nan': fills missing data "
#~ "with NaN values: [1, 2, 3] fills"
#~ " with: [NaN, 1, NaN, 2, NaN, 3,"
#~ " NaN] - 'zero': fills missing data"
#~ " with 0 values: [1, 2, 3] fills"
#~ " with: [0, 1, 0, 2, 0 , "
#~ "3, 0] b_days_only: bool, default True"
#~ " Whether to force the conversion of"
#~ " natural day frequencies to weekdays, "
#~ "i.e.: 'D' -> 'B' 'W' -> 'W-FRI'"
#~ " 'M' -> 'BM' trade_time_only: bool, "
#~ "default True Only data within the "
#~ "trade time period will be generated, "
#~ "the parameters for the trade time "
#~ "period are set by **kwarg. The "
#~ "parameters of the trade_time_only are "
#~ "set by **kwargs include_start: bool, "
#~ "default True Whether the date time "
#~ "series contains a start date/time "
#~ "include_end: bool, default True Whether "
#~ "the date time series contains an "
#~ "end date/time start_am:, str The start"
#~ " of the morning trade session "
#~ "start_am:, str The start time of "
#~ "the morning session end_am:, str The "
#~ "end time of the morning session "
#~ "include_start_am: bool Whether the morning "
#~ "session includes the start time "
#~ "include_end_am: bool Whether the morning "
#~ "session includes the end time start_pm:"
#~ " str The start time of the "
#~ "afternoon session end_pm: str The end"
#~ " time of the afternoon session "
#~ "include_start_am: bool, default True End "
#~ "time of the afternoon session "
#~ "include_start_pm: bool Whether or not "
#~ "the afternoon session includes a start"
#~ " time include_end_pm: bool Whether or "
#~ "not the afternoon session includes an"
#~ " end time"

