msgid "§0 开场最小可跑"
msgstr "§0 Minimal runnable kickoff"

#: ../../source/tutorials/2.6-historypanel-advanced-vertical-timeaxis.md
msgid "证明 `get_kline -> plot` 链路通了"
msgstr "Prove the `get_kline -> plot` pipeline works"

#: ../../source/tutorials/2.6-historypanel-advanced-vertical-timeaxis.md
msgid "`img/3.1_pf_compare.png`"
msgstr "`img/3.1_pf_compare.png`"

#: ../../source/tutorials/2.6-historypanel-advanced-vertical-timeaxis.md
msgid "§0.5 或 §6"
msgstr "§0.5 or §6"

#: ../../source/tutorials/2.6-historypanel-advanced-vertical-timeaxis.md
msgid "`LONG/SHORT/000300.SH` 归一化曲线对比"
msgstr "Normalized curve comparison of `LONG/SHORT/000300.SH`"

#: ../../source/tutorials/2.6-historypanel-advanced-vertical-timeaxis.md
msgid "`img/3.1_highlight_one_share.png`"
msgstr "`img/3.1_highlight_one_share.png`"

#: ../../source/tutorials/2.6-historypanel-advanced-vertical-timeaxis.md
msgid "§7"
msgstr "§7"

#: ../../source/tutorials/2.6-historypanel-advanced-vertical-timeaxis.md
msgid "单股图上高亮触发点（便于复盘解释）"
msgstr "Highlight trigger points on a single-stock chart (for easier review and explanation)"
