msgid "模块总览：`live_trading/1-overview.md`"
msgstr "Module overview: `live_trading/1-overview.md`"

#: ../../source/design/10-live-trading-s1.3-architecture.md:77
msgid "运行与配置：`live_trading/2-configuration-and-run.md`"
msgstr ""
"Operation and configuration: `live_trading/2-configuration-and-run.md`"

